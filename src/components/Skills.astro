---
import { cva } from 'class-variance-authority'

const content = [
  {
    subtitle: 'MOBILE',
    list: ['SwiftUI / Swift', 'Kotlin / Android', 'iOS & Android platforms', 'Cross-platform patterns'],
  },
  {
    subtitle: 'ENGINEERING',
    list: ['Data architecture', 'Backend integration', 'Security controls'],
  },
  {
    subtitle: 'LEADERSHIP',
    list: ['Agile / Scrum', 'Technical documentation', 'UX/UI decision making', 'Risk management'],
  },
]

const style = {
  container: cva(['px-6', 'py-10', 'md:px-10', 'md:py-16']),
  title: cva([
    "after:content-['']",
    'after:bg-white/10',
    'after:h-px',
    'after:w-20',
    'flex',
    'font-mono',
    'gap-4',
    'items-center',
    'mb-10',
    'text-[10px]',
    'text-primary-500',
    'tracking-[0.18em]',
    'uppercase',
  ]),
  list: cva(['grid', 'grid-cols-1', 'gap-6', 'md:grid-cols-3']),
  item: cva([
    'border',
    'border-white/8',
    'duration-20',
    'hover:-translate-y-1',
    'hover:bg-white/6',
    'p-6',
    'rounded-sm',
    'transition-all',
  ]),
  subtitle: cva(['mb-4', 'font-mono', 'text-[9px]', 'tracking-[0.18em]', 'text-primary-500']),
  keyword: cva(['text-sm', 'font-light', 'text-white/60']),
}
---

<section id="skills" class={style.container()}>
  <p class={style.title()}>Skills</p>
  <div class={style.list()}>
    {
      content.map((c) => (
        <div class={style.item()}>
          <p class={style.subtitle()}>{c.subtitle}</p>
          <div class="space-y-2">
            {c.list.map((k) => (
              <p class={style.keyword()}>{k}</p>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
