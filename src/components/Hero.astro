---
import { cva } from 'class-variance-authority'

import { Path } from '@pt/path'

const style = {
  container: cva(['max-w-4xl', 'px-6', 'pt-12', 'pb-12', 'md:px-10', 'md:pt-20', 'md:pb-16']),
  paragraph: cva(['mb-5', 'font-mono', 'text-[11px]', 'tracking-[0.15em]', 'text-primary-500', 'uppercase']),
  name: cva(['font-display', 'mb-1', 'text-5xl', 'leading-[1.05]', 'font-normal', 'text-secondary-700', 'md:text-7xl']),
  slogan: cva([
    'font-display',
    'font-normal',
    'italic',
    'leading-[1.05]',
    'mb-6',
    'md:mb-8',
    'md:text-7xl',
    'text-5xl',
    'text-primary-500',
  ]),
  line: cva(['text-content-300', 'mb-8', 'max-w-lg', 'text-base', 'leading-relaxed', 'font-light', 'md:mb-10']),
  linkList: cva(['flex', 'flex-col', 'gap-3', 'sm:flex-row', 'md:gap-4']),
  linkResume: cva([
    'bg-primary-500',
    'duration-200',
    'font-medium',
    'hover:-translate-y-1',
    'px-7',
    'py-3',
    'rounded-sm',
    'text-center',
    'text-fill-page',
    'text-sm',
    'tracking-wide',
    'transition-all',
  ]),
  linkProject: cva([
    'border',
    'border-white/20',
    'font-light',
    'hover:border-white/40',
    'px-7',
    'py-3',
    'rounded-sm',
    'text-center',
    'text-sm',
    'text-white/50',
    'tracking-wide',
    'transition-colors',
  ]),
}
---

<section class={style.container()}>
  <p class={style.paragraph()}>Tech Lead · Mobile · Fintech</p>
  <h1 class={style.name()}>Wilbert Veloz</h1>
  <h2 class={style.slogan()}>build things that matter.</h2>
  <p class={style.line()}>
    Software engineer and tech lead with 3–5 years shaping mobile experiences for one of the Dominican Republic's most
    popular banking platforms. End-to-end ownership — from architecture to deployment.
  </p>
  <div class={style.linkList()}>
    <a href={Path.Resume} download="Wilbert_Veloz_Resume.pdf" class={style.linkResume()}>Download Resume</a>
    <a href={Path.Work} class={style.linkProject()}>View Projects</a>
  </div>
</section>
