---
import { cva } from 'class-variance-authority'

import logo from '@pt/assets/logo.svg?raw'
import { Path } from '@pt/path'

const style = {
  container: cva(['flex', 'items-center', 'justify-between', 'border-b', 'border-white/10', 'px-6', 'py-5']),
  linkRoot: cva(['flex', 'items-center', 'transition-opacity', 'hover:opacity-80']),
  list: cva(['hidden', 'list-none', 'gap-8', 'md:flex']),
  link: cva(['text-xs', 'tracking-widest', 'text-white/40', 'transition-colors', 'hover:text-white/70']),
}

const mobile = {
  container: cva([
    'hidden',
    'flex-col',
    'items-start',
    'gap-6',
    'border-b',
    'border-white/10',
    'bg-fill-page',
    'px-6',
    'py-8',
    'md:hidden',
  ]),
}

const nav = [
  { href: Path.Root, label: 'HOME' },
  { href: Path.Work, label: '> WORK' },
  { href: Path.Skill, label: '> SKILLS' },
  { href: Path.About, label: '> ABOUT' },
  { href: Path.Contact, label: 'CONTACT' },
]
---

<nav class={style.container()}>
  <a href={Path.Root} class={style.linkRoot()}>
    <div set:html={logo} style="width: 36px; height: 36px; flex-shrink: 0;" />
  </a>

  <ul class={style.list()}>
    <li>
      {
        nav.map((n) => (
          <a href={n.href} class={style.link()}>
            {n.label}
          </a>
        ))
      }
    </li>
  </ul>

  <button id="menu-btn" class="flex flex-col gap-1.5 p-2 md:hidden" aria-label="Menu">
    <span class="block h-px w-5 bg-secondary-500/60 transition-all duration-300" id="line1"></span>
    <span class="block h-px w-5 bg-secondary-500/60 transition-all duration-300" id="line2"></span>
    <span class="block h-px w-5 bg-secondary-500/60 transition-all duration-300" id="line3"></span>
  </button>
</nav>

<div id="mobile-menu" class={mobile.container()}>
  {
    nav.map((n) => (
      <a href={n.href} class={style.link()}>
        {n.label}
      </a>
    ))
  }
</div>

<script>
  const btn = document.getElementById('menu-btn')
  const menu = document.getElementById('mobile-menu')
  const line1 = document.getElementById('line1')
  const line2 = document.getElementById('line2')
  const line3 = document.getElementById('line3')

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden')
    if (isOpen) {
      menu?.classList.add('hidden')
      menu?.classList.remove('flex')
      if (line1) line1.style.transform = ''
      if (line2) line2.style.opacity = '1'
      if (line3) line3.style.transform = ''
    } else {
      menu?.classList.remove('hidden')
      menu?.classList.add('flex')
      if (line1) line1.style.transform = 'translateY(6px) rotate(45deg)'
      if (line2) line2.style.opacity = '0'
      if (line3) line3.style.transform = 'translateY(-6px) rotate(-45deg)'
    }
  })
</script>
