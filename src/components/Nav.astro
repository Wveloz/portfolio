---
import logo from '@pt/assets/logo.svg?raw'
---

<nav class="flex items-center justify-between border-b border-white/10 px-6 py-5">
  <a href="/" class="flex items-center transition-opacity hover:opacity-80">
    <div set:html={logo} style="width: 36px; height: 36px; flex-shrink: 0;" />
  </a>

  <ul class="hidden list-none gap-8 md:flex">
    <li>
      <a href="/" class="text-xs tracking-widest text-white/40 uppercase transition-colors hover:text-white/70">Home</a>
    </li>
    <li>
      <a href="/work" class="text-xs tracking-widest text-white/40 uppercase transition-colors hover:text-white/70"
        >Work</a
      >
    </li>
    <li>
      <a href="/skills" class="text-xs tracking-widest text-white/40 uppercase transition-colors hover:text-white/70"
        >Skills</a
      >
    </li>
    <li>
      <a href="/about" class="text-xs tracking-widest text-white/40 uppercase transition-colors hover:text-white/70"
        >About</a
      >
    </li>
    <li>
      <a href="/contact" class="text-xs tracking-widest text-white/40 uppercase transition-colors hover:text-white/70"
        >Contact</a
      >
    </li>
  </ul>

  <button id="menu-btn" class="flex flex-col gap-1.5 p-2 md:hidden" aria-label="Menu">
    <span class="block h-px w-5 bg-white/60 transition-all duration-300" id="line1"></span>
    <span class="block h-px w-5 bg-white/60 transition-all duration-300" id="line2"></span>
    <span class="block h-px w-5 bg-white/60 transition-all duration-300" id="line3"></span>
  </button>
</nav>

<div
  id="mobile-menu"
  class="hidden flex-col items-start gap-6 border-b border-white/10 bg-[#0f0e0c] px-6 py-8 md:hidden"
>
  <a href="/" class="text-xs tracking-widest text-white/40 uppercase transition-colors hover:text-[#c9873a]">Home</a>
  <a href="/work" class="text-xs tracking-widest text-white/40 uppercase transition-colors hover:text-[#c9873a]">Work</a
  >
  <a href="/skills" class="text-xs tracking-widest text-white/40 uppercase transition-colors hover:text-[#c9873a]"
    >Skills</a
  >
  <a href="/about" class="text-xs tracking-widest text-white/40 uppercase transition-colors hover:text-[#c9873a]"
    >About</a
  >
  <a href="/contact" class="text-xs tracking-widest text-white/40 uppercase transition-colors hover:text-[#c9873a]"
    >Contact</a
  >
</div>

<script>
  const btn = document.getElementById('menu-btn')
  const menu = document.getElementById('mobile-menu')
  const line1 = document.getElementById('line1')
  const line2 = document.getElementById('line2')
  const line3 = document.getElementById('line3')

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden')
    if (isOpen) {
      menu?.classList.add('hidden')
      menu?.classList.remove('flex')
      if (line1) line1.style.transform = ''
      if (line2) line2.style.opacity = '1'
      if (line3) line3.style.transform = ''
    } else {
      menu?.classList.remove('hidden')
      menu?.classList.add('flex')
      if (line1) line1.style.transform = 'translateY(6px) rotate(45deg)'
      if (line2) line2.style.opacity = '0'
      if (line3) line3.style.transform = 'translateY(-6px) rotate(-45deg)'
    }
  })
</script>
