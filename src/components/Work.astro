---
import { cva } from 'class-variance-authority'

const content = [
  {
    project: 'Banco Popular Mobile',
    institution: 'Banco Popular Dominicano · iOS & Android',
    role: 'Tech Lead',
    description:
      'Full-featured banking app giving clients access to their finances, transfers, transactions, reclamations and account management — entirely from their phone. Contributed to UX/UI decisions, data architecture, backend service design, and led deployment across dev, QA, and production environments.',
    keywords: ['SwiftUI', 'Kotlin', 'iOS', 'Android', 'Agile', 'CI/CD'],
  },
  {
    project: 'Toke',
    institution: 'Banco Popular · Payment Infrastructure',
    role: 'Latest',
    description:
      'Payment infrastructure initiative launched by Banco Popular to transform financial inclusion across the Dominican Republic. Participated in development of the feature in the App.',
    keywords: ['Payments', 'Financial Inclusion', 'Backend Services', 'Security'],
  },
]

const style = {
  container: cva(['px-10', 'py-16']),
  title: cva([
    "after:content-['']",
    'after:bg-white/10',
    'after:h-px',
    'after:w-20',
    'flex',
    'font-mono',
    'gap-4',
    'items-center',
    'mb-10',
    'text-primary-500',
    'text-xs',
    'tracking-[0.18em]',
  ]),
  card: cva([
    'bg-white/3',
    'border',
    'border-white/10',
    'duration-200',
    'hover:-translate-y-1',
    'hover:bg-white/6',
    'mb-4',
    'p-8',
    'rounded-sm',
    'transition-all',
  ]),
  header: cva(['mb-4', 'flex items-start', 'justify-between']),
  project: cva(['font-display mb-1 text-2xl text-secondary-500']),
  institution: cva(['text-xs', 'tracking-wide', 'text-content-500/40', 'uppercase']),
  role: cva([
    'border',
    'border-primary-500/40',
    'font-mono',
    'px-3',
    'py-1',
    'text-primary-500',
    'text-xs',
    'tracking-widest',
  ]),
  description: cva(['mb-5', 'text-sm', 'leading-relaxed', 'font-light', 'text-content-500/50']),
  list: cva(['flex', 'flex-wrap', 'gap-2']),
  keyword: cva([
    'bg-white/5',
    'border',
    'border-white/10',
    'font-mono',
    'px-3',
    'py-1',
    'text-[10px]',
    'text-secondary-500/40',
  ]),
}
---

<section id="work" class={style.container()}>
  <p class={style.title()}>Selected work</p>

  {
    content.map((c) => (
      <div class={style.card()}>
        <div class={style.header()}>
          <div>
            <h3 class={style.project()}>{c.institution}</h3>
            <p class={style.institution()}>{c.project}</p>
          </div>
          <span class={style.role()}>{c.role}</span>
        </div>
        <p class={style.description()}>{c.description}</p>
        <div class={style.list()}>
          {c.keywords.map((k) => (
            <span class={style.keyword()}>{k}</span>
          ))}
        </div>
      </div>
    ))
  }
</section>
