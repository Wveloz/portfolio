---
import { cva } from 'class-variance-authority'

import { Path } from '@pt/path'

import BaseLayout from './BaseLayout.astro'

interface Props {
  title: string
  company: string
  period: string
  role: string
  category: string
  stack: string[]
}

const { title, company, period, role, category, stack } = Astro.props

const style = {
  container: cva(['max-w-3xl', 'px-10', 'pt-16', 'pb-8']),
  link: cva([
    'font-mono',
    'hover:text-primary-500',
    'inline-block',
    'mb-8',
    'text-xs',
    'text-white/30',
    'tracking-widest',
    'transition-colors',
  ]),
  company: cva(['mb-3', 'font-mono', 'text-xs', 'tracking-widest', 'text-primary-500', 'uppercase']),
  title: cva(['font-display', 'mb-2', 'text-6xl', 'font-normal', 'text-secondary-500']),
  role: cva(['font-display', 'mb-8', 'text-2xl', 'font-normal', 'text-primary-500', 'italic']),
  list: cva(['mb-10', 'flex', 'flex-wrap', 'gap-2']),
  item: cva([
    'border',
    'border-white/10',
    'cursor-default',
    'duration-200',
    'font-mono',
    'hover:-translate-y-1',
    'hover:border-primary-500/50 hover:text-primary-500',
    'px-4',
    'py-2',
    'text-white/50',
    'text-xs',
    'tracking-wide',
    'transition-all',
    'transition-colors',
  ]),
  divider: cva(['mx-10', 'mb-12', 'border-white/8']),
  slot: cva(['max-w-3xl', 'px-10', 'pb-20']),
}
---

<BaseLayout title={title}>
  <section class={style.container()}>
    <a href={Path.Work} class={style.link()}>← ALL PROJECTS</a>
    <p class={style.company()}>{company} · {period}</p>
    <h1 class={style.title()}>{title}</h1>
    <p class={style.role()}>{category} · {role}</p>
    <div class={style.list()}>
      {stack.map((tag) => <span class={style.item()}>{tag}</span>)}
    </div>
  </section>

  <hr class={style.divider()} />

  <section class={style.slot()}>
    <slot />
  </section>
</BaseLayout>
