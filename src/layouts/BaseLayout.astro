---
import { cva } from 'class-variance-authority'

import '@pt/styles/global.css'
import Nav from '@pt/components/Nav.astro'

interface Props {
  title: string
}

const { title } = Astro.props

const style = {
  body: cva(['bg-fill-page', 'font-sans', 'text-content-500']),
  footer: cva(['flex', 'items-center', 'justify-between', 'border-t', 'border-white/6', 'px-10', 'py-8']),
  footerContent: cva(['font-mono', 'text-[11px]', 'text-white/20']),
}
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Wilbert Veloz</title>
    <style>
      html,
      body {
        background-color: var(--color-fill-page) !important;
      }
      main-content {
        animation: pageFadeIn 0.6s ease forwards;
      }
      @keyframes pageFadeIn {
        from {
          opacity: 0;
          transform: translateY(var(--spacing-2));
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=DM+Mono:wght@300;400&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <link href="https://fonts.googleapis.com/css2?family=Inconsolata:wght@200..900&display=swap" rel="stylesheet" />
  </head>
  <body class={style.body()}>
    <div id="page-transition"></div>

    <Nav />
    <div style="animation: pageFadeIn 0.6s ease forwards;">
      <slot />
    </div>

    <footer class={style.footer()}>
      <span class={style.footerContent()}>Wilbert Veloz · Santo Domingo, DR</span>
      <span class={style.footerContent()}>© 2025 Wilbert Veloz. All rights reserved.</span>
    </footer>
  </body>
</html>
