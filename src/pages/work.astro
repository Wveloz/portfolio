---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Work">

  <section class="px-10 pt-16 pb-8 max-w-4xl">
    <a href="/" class="font-mono text-[10px] tracking-widest uppercase text-white/30 hover:text-[#c9873a] transition-colors mb-8 inline-block">← Back</a>
    <p class="font-mono text-[11px] tracking-[0.15em] uppercase text-[#c9873a] mb-4">Selected work</p>
    <h1 class="font-display text-6xl font-normal text-[#e8e0d0] mb-4">Projects</h1>
    <p class="text-base leading-relaxed text-white/50 font-light max-w-lg">A collection of apps and features I've helped design, build, and ship — across fintech and health & wellness.</p>
  </section>

  <hr class="border-white/8 mx-10 mb-12" />

  <section class="px-10 pb-20">
    <div class="grid grid-cols-1 gap-6">

<a href="/work/banco-popular" class="group block border border-white/10 rounded-sm p-8 bg-white/[0.03] hover:bg-white/[0.06] hover:-translate-y-1 transition-all duration-200">        <div class="flex justify-between items-start mb-4">
          <div>
            <p class="font-mono text-[10px] tracking-widest uppercase text-[#c9873a] mb-2">Banco Popular Dominicano · 2023 – Present</p>
            <h2 class="font-display text-3xl text-[#e8e0d0] mb-1 group-hover:text-[#c9873a] transition-colors">App Popular</h2>
            <p class="text-sm text-white/40 font-light">Financial · iOS & Android</p>
          </div>
          <span class="font-mono text-[10px] text-[#c9873a] border border-[#c9873a]/40 px-3 py-1 tracking-widest">Tech Lead</span>
        </div>
        <p class="text-sm leading-relaxed text-white/50 font-light mb-5 max-w-2xl">Full-featured banking app serving clients across the Dominican Republic — transfers, transactions, claims, and account management without visiting a branch. Includes Toke, a payment infrastructure feature for financial inclusion.</p>
        <div class="flex flex-wrap gap-2 mb-6">
          <span class="font-mono text-[10px] text-[#e8e0d0]/40 bg-white/5 border border-white/10 px-3 py-1">SwiftUI</span>
          <span class="font-mono text-[10px] text-[#e8e0d0]/40 bg-white/5 border border-white/10 px-3 py-1">Kotlin</span>
          <span class="font-mono text-[10px] text-[#e8e0d0]/40 bg-white/5 border border-white/10 px-3 py-1">iOS</span>
          <span class="font-mono text-[10px] text-[#e8e0d0]/40 bg-white/5 border border-white/10 px-3 py-1">Android</span>
          <span class="font-mono text-[10px] text-[#e8e0d0]/40 bg-white/5 border border-white/10 px-3 py-1">Agile</span>
        </div>
        <span class="font-mono text-[10px] tracking-widest uppercase text-[#c9873a] group-hover:underline">View project →</span>
      </a>

<a href="/work/newtopia" class="group block border border-white/10 rounded-sm p-8 bg-white/[0.03] hover:bg-white/[0.06] hover:-translate-y-1 transition-all duration-200">        <div class="flex justify-between items-start mb-4">
          <div>
            <p class="font-mono text-[10px] tracking-widest uppercase text-[#c9873a] mb-2">Tashi · 2022 – 2023</p>
            <h2 class="font-display text-3xl text-[#e8e0d0] mb-1 group-hover:text-[#c9873a] transition-colors">Newtopia</h2>
            <p class="text-sm text-white/40 font-light">Health & Wellness · iOS & Android</p>
          </div>
          <span class="font-mono text-[10px] text-[#c9873a] border border-[#c9873a]/40 px-3 py-1 tracking-widest">QA Lead</span>
        </div>
        <p class="text-sm leading-relaxed text-white/50 font-light mb-5 max-w-2xl">Health and wellness app built with React Native. Led a team of testers ensuring quality assurance was deeply embedded throughout the software lifecycle.</p>
        <div class="flex flex-wrap gap-2 mb-6">
          <span class="font-mono text-[10px] text-[#e8e0d0]/40 bg-white/5 border border-white/10 px-3 py-1">React Native</span>
          <span class="font-mono text-[10px] text-[#e8e0d0]/40 bg-white/5 border border-white/10 px-3 py-1">QA</span>
          <span class="font-mono text-[10px] text-[#e8e0d0]/40 bg-white/5 border border-white/10 px-3 py-1">iOS & Android</span>
        </div>
        <span class="font-mono text-[10px] tracking-widest uppercase text-[#c9873a] group-hover:underline">View project →</span>
      </a>

<a href="/work/fulfill" class="group block border border-white/10 rounded-sm p-8 bg-white/[0.03] hover:bg-white/[0.06] hover:-translate-y-1 transition-all duration-200">        <div class="flex justify-between items-start mb-4">
          <div>
            <p class="font-mono text-[10px] tracking-widest uppercase text-[#c9873a] mb-2">Tashi · 2021 – 2022</p>
            <h2 class="font-display text-3xl text-[#e8e0d0] mb-1 group-hover:text-[#c9873a] transition-colors">FullFill</h2>
            <p class="text-sm text-white/40 font-light">Health & Wellness · iOS & Android</p>
          </div>
          <span class="font-mono text-[10px] text-[#c9873a] border border-[#c9873a]/40 px-3 py-1 tracking-widest">QA Analyst</span>
        </div>
        <p class="text-sm leading-relaxed text-white/50 font-light mb-5 max-w-2xl">Health and wellness app built with React Native. Responsible for organizing, tracking, and managing the full test process to ensure software quality across releases.</p>
        <div class="flex flex-wrap gap-2 mb-6">
          <span class="font-mono text-[10px] text-[#e8e0d0]/40 bg-white/5 border border-white/10 px-3 py-1">React Native</span>
          <span class="font-mono text-[10px] text-[#e8e0d0]/40 bg-white/5 border border-white/10 px-3 py-1">QA</span>
          <span class="font-mono text-[10px] text-[#e8e0d0]/40 bg-white/5 border border-white/10 px-3 py-1">iOS & Android</span>
        </div>
        <span class="font-mono text-[10px] tracking-widest uppercase text-[#c9873a] group-hover:underline">View project →</span>
      </a>

    </div>
  </section>

</BaseLayout>
