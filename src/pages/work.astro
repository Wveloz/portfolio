---
import BaseLayout from '@pt/layouts/BaseLayout.astro'
---

<BaseLayout title="Work">
  <section class="max-w-4xl px-10 pt-16 pb-8">
    <a
      href="/"
      class="mb-8 inline-block font-mono text-[10px] tracking-widest text-white/30 uppercase transition-colors hover:text-[#c9873a]"
      >← Back</a
    >
    <p class="mb-4 font-mono text-[11px] tracking-[0.15em] text-[#c9873a] uppercase">Selected work</p>
    <h1 class="font-display mb-4 text-6xl font-normal text-[#e8e0d0]">Projects</h1>
    <p class="max-w-lg text-base leading-relaxed font-light text-white/50">
      A collection of apps and features I've helped design, build, and ship — across fintech and health & wellness.
    </p>
  </section>

  <hr class="mx-10 mb-12 border-white/8" />

  <section class="px-10 pb-20">
    <div class="grid grid-cols-1 gap-6">
      <a
        href="/work/banco-popular"
        class="group block rounded-sm border border-white/10 bg-white/[0.03] p-8 transition-all duration-200 hover:-translate-y-1 hover:bg-white/[0.06]"
      >
        <div class="mb-4 flex items-start justify-between">
          <div>
            <p class="mb-2 font-mono text-[10px] tracking-widest text-[#c9873a] uppercase">
              Banco Popular Dominicano · 2023 – Present
            </p>
            <h2 class="font-display mb-1 text-3xl text-[#e8e0d0] transition-colors group-hover:text-[#c9873a]">
              App Popular
            </h2>
            <p class="text-sm font-light text-white/40">Financial · iOS & Android</p>
          </div>
          <span class="border border-[#c9873a]/40 px-3 py-1 font-mono text-[10px] tracking-widest text-[#c9873a]"
            >Tech Lead</span
          >
        </div>
        <p class="mb-5 max-w-2xl text-sm leading-relaxed font-light text-white/50">
          Full-featured banking app serving clients across the Dominican Republic — transfers, transactions, claims, and
          account management without visiting a branch. Includes Toke, a payment infrastructure feature for financial
          inclusion.
        </p>
        <div class="mb-6 flex flex-wrap gap-2">
          <span class="border border-white/10 bg-white/5 px-3 py-1 font-mono text-[10px] text-[#e8e0d0]/40"
            >SwiftUI</span
          >
          <span class="border border-white/10 bg-white/5 px-3 py-1 font-mono text-[10px] text-[#e8e0d0]/40">Kotlin</span
          >
          <span class="border border-white/10 bg-white/5 px-3 py-1 font-mono text-[10px] text-[#e8e0d0]/40">iOS</span>
          <span class="border border-white/10 bg-white/5 px-3 py-1 font-mono text-[10px] text-[#e8e0d0]/40"
            >Android</span
          >
          <span class="border border-white/10 bg-white/5 px-3 py-1 font-mono text-[10px] text-[#e8e0d0]/40">Agile</span>
        </div>
        <span class="font-mono text-[10px] tracking-widest text-[#c9873a] uppercase group-hover:underline"
          >View project →</span
        >
      </a>

      <a
        href="/work/newtopia"
        class="group block rounded-sm border border-white/10 bg-white/[0.03] p-8 transition-all duration-200 hover:-translate-y-1 hover:bg-white/[0.06]"
      >
        <div class="mb-4 flex items-start justify-between">
          <div>
            <p class="mb-2 font-mono text-[10px] tracking-widest text-[#c9873a] uppercase">Tashi · 2022 – 2023</p>
            <h2 class="font-display mb-1 text-3xl text-[#e8e0d0] transition-colors group-hover:text-[#c9873a]">
              Newtopia
            </h2>
            <p class="text-sm font-light text-white/40">Health & Wellness · iOS & Android</p>
          </div>
          <span class="border border-[#c9873a]/40 px-3 py-1 font-mono text-[10px] tracking-widest text-[#c9873a]"
            >QA Lead</span
          >
        </div>
        <p class="mb-5 max-w-2xl text-sm leading-relaxed font-light text-white/50">
          Health and wellness app built with React Native. Led a team of testers ensuring quality assurance was deeply
          embedded throughout the software lifecycle.
        </p>
        <div class="mb-6 flex flex-wrap gap-2">
          <span class="border border-white/10 bg-white/5 px-3 py-1 font-mono text-[10px] text-[#e8e0d0]/40"
            >React Native</span
          >
          <span class="border border-white/10 bg-white/5 px-3 py-1 font-mono text-[10px] text-[#e8e0d0]/40">QA</span>
          <span class="border border-white/10 bg-white/5 px-3 py-1 font-mono text-[10px] text-[#e8e0d0]/40"
            >iOS & Android</span
          >
        </div>
        <span class="font-mono text-[10px] tracking-widest text-[#c9873a] uppercase group-hover:underline"
          >View project →</span
        >
      </a>

      <a
        href="/work/fulfill"
        class="group block rounded-sm border border-white/10 bg-white/[0.03] p-8 transition-all duration-200 hover:-translate-y-1 hover:bg-white/[0.06]"
      >
        <div class="mb-4 flex items-start justify-between">
          <div>
            <p class="mb-2 font-mono text-[10px] tracking-widest text-[#c9873a] uppercase">Tashi · 2021 – 2022</p>
            <h2 class="font-display mb-1 text-3xl text-[#e8e0d0] transition-colors group-hover:text-[#c9873a]">
              FullFill
            </h2>
            <p class="text-sm font-light text-white/40">Health & Wellness · iOS & Android</p>
          </div>
          <span class="border border-[#c9873a]/40 px-3 py-1 font-mono text-[10px] tracking-widest text-[#c9873a]"
            >QA Analyst</span
          >
        </div>
        <p class="mb-5 max-w-2xl text-sm leading-relaxed font-light text-white/50">
          Health and wellness app built with React Native. Responsible for organizing, tracking, and managing the full
          test process to ensure software quality across releases.
        </p>
        <div class="mb-6 flex flex-wrap gap-2">
          <span class="border border-white/10 bg-white/5 px-3 py-1 font-mono text-[10px] text-[#e8e0d0]/40"
            >React Native</span
          >
          <span class="border border-white/10 bg-white/5 px-3 py-1 font-mono text-[10px] text-[#e8e0d0]/40">QA</span>
          <span class="border border-white/10 bg-white/5 px-3 py-1 font-mono text-[10px] text-[#e8e0d0]/40"
            >iOS & Android</span
          >
        </div>
        <span class="font-mono text-[10px] tracking-widest text-[#c9873a] uppercase group-hover:underline"
          >View project →</span
        >
      </a>
    </div>
  </section>
</BaseLayout>
