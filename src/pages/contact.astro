---
import BaseLayout from '@pt/layouts/BaseLayout.astro'
---

<BaseLayout title="Contact">
  <div class="grid min-h-[600px] grid-cols-1 md:grid-cols-2">
    <!-- LEFT -->
    <div class="flex flex-col justify-between border-r border-white/[0.08] px-10 py-16">
      <div>
        <a
          href="/"
          class="mb-8 inline-block font-mono text-[10px] tracking-widest text-white/30 uppercase transition-colors hover:text-[#c9873a]"
          >← Back</a
        >
        <p class="mb-4 font-mono text-[11px] tracking-[0.15em] text-[#c9873a] uppercase">Get in touch</p>
        <h1 class="font-display mb-1 text-6xl font-normal text-[#e8e0d0]">Let's build</h1>
        <h2 class="font-display mb-8 text-6xl font-normal text-[#c9873a] italic">something great.</h2>
        <p class="max-w-sm text-sm leading-relaxed font-light text-white/45">
          Whether you have a project in mind, want to talk shop about mobile engineering, or just want to connect — I'm
          always open to a good conversation.
        </p>
      </div>

      <div class="divide-y divide-white/[0.08]">
        <div class="flex items-center justify-between py-4">
          <span class="font-mono text-[9px] tracking-widest text-white/25 uppercase">LinkedIn</span>
          <a
            href="https://www.linkedin.com/in/wilbert-veloz-22409821a/"
            target="_blank"
            class="border-b border-white/20 pb-px text-sm font-light text-white/55 transition-colors hover:text-white/80"
            >Wilbert Veloz</a
          >
        </div>
        <div class="flex items-center justify-between py-4">
          <span class="font-mono text-[9px] tracking-widest text-white/25 uppercase">GitHub</span>
          <a
            href="https://github.com/Wveloz"
            target="_blank"
            class="border-b border-white/20 pb-px text-sm font-light text-white/55 transition-colors hover:text-white/80"
            >Wveloz</a
          >
        </div>
        <div class="flex items-center justify-between py-4">
          <span class="font-mono text-[9px] tracking-widest text-white/25 uppercase">Email</span>
          <a
            href="mailto:velozwilbert@gmail.com"
            class="border-b border-white/20 pb-px text-sm font-light text-white/55 transition-colors hover:text-white/80"
            >velozwilbert@gmail.com</a
          >
        </div>
        <div class="flex items-center justify-between py-4">
          <span class="font-mono text-[9px] tracking-widest text-white/25 uppercase">Location</span>
          <span class="text-sm font-light text-white/55">Santo Domingo, DR</span>
        </div>
      </div>
    </div>

    <!-- RIGHT -->
    <div class="flex flex-col justify-center px-10 py-16">
      <p class="mb-8 font-mono text-[10px] tracking-[0.18em] text-[#c9873a] uppercase">Send a message</p>

      <form id="contact-form" action="https://formspree.io/f/xbdpyzeo" method="POST">
        <div class="mb-6 grid grid-cols-2 gap-4">
          <div>
            <label class="mb-2 block font-mono text-[9px] tracking-widest text-white/30 uppercase">Name</label>
            <input
              type="text"
              name="name"
              placeholder="Your name"
              required
              class="w-full border border-white/10 bg-white/[0.03] px-4 py-3 text-sm font-light text-[#e8e0d0] transition-colors outline-none placeholder:text-white/20 focus:border-[#c9873a]/50"
            />
          </div>
          <div>
            <label class="mb-2 block font-mono text-[9px] tracking-widest text-white/30 uppercase">Email</label>
            <input
              type="email"
              name="email"
              placeholder="your@email.com"
              required
              class="w-full border border-white/10 bg-white/[0.03] px-4 py-3 text-sm font-light text-[#e8e0d0] transition-colors outline-none placeholder:text-white/20 focus:border-[#c9873a]/50"
            />
          </div>
        </div>

        <div class="mb-6">
          <label class="mb-2 block font-mono text-[9px] tracking-widest text-white/30 uppercase">Subject</label>
          <input
            type="text"
            name="subject"
            placeholder="What's this about?"
            required
            class="w-full border border-white/10 bg-white/[0.03] px-4 py-3 text-sm font-light text-[#e8e0d0] transition-colors outline-none placeholder:text-white/20 focus:border-[#c9873a]/50"
          />
        </div>

        <div class="mb-8">
          <label class="mb-2 block font-mono text-[9px] tracking-widest text-white/30 uppercase">Message</label>
          <textarea
            name="message"
            placeholder="Tell me about your project or idea..."
            required
            rows="5"
            class="w-full resize-none border border-white/10 bg-white/[0.03] px-4 py-3 text-sm font-light text-[#e8e0d0] transition-colors outline-none placeholder:text-white/20 focus:border-[#c9873a]/50"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-[#c9873a] py-4 font-mono text-[10px] font-medium tracking-widest text-[#0f0e0c] uppercase transition-all transition-colors duration-200 hover:-translate-y-1 hover:bg-[#b87830]"
        >
          Send message →
        </button>
      </form>
      <div id="success-msg" class="mt-8 hidden border border-[#c9873a]/30 bg-[#c9873a]/5 px-6 py-5">
        <p class="mb-2 font-mono text-[10px] tracking-widest text-[#c9873a] uppercase">Message sent</p>
        <p class="text-sm font-light text-white/50">Thanks for reaching out — I'll get back to you soon.</p>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null
    const success = document.getElementById('success-msg') as HTMLElement | null
    if (form && success) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault()

        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null
        if (btn) {
          btn.textContent = 'Sending...'
          btn.disabled = true
        }

        const data = new FormData(form)

        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: data,
            headers: { Accept: 'application/json' },
          })

          if (res.ok) {
            form.style.opacity = '0'
            form.style.transition = 'opacity 0.4s ease'
            setTimeout(() => {
              form.style.display = 'none'
              success.classList.remove('hidden')
              success.style.opacity = '0'
              success.style.transition = 'opacity 0.4s ease'
              setTimeout(() => (success.style.opacity = '1'), 50)
            }, 400)
          } else {
            if (btn) {
              btn.textContent = 'Something went wrong — try again'
              btn.disabled = false
            }
          }
        } catch {
          if (btn) {
            btn.textContent = 'Something went wrong — try again'
            btn.disabled = false
          }
        }
      })
    }
  </script>
</BaseLayout>
