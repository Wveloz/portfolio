---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact">

  <div class="grid grid-cols-2 min-h-[600px]">

    <!-- LEFT -->
    <div class="px-10 py-16 border-r border-white/[0.08] flex flex-col justify-between">
      <div>
        <a href="/" class="font-mono text-[10px] tracking-widest uppercase text-white/30 hover:text-[#c9873a] transition-colors mb-8 inline-block">← Back</a>
        <p class="font-mono text-[11px] tracking-[0.15em] uppercase text-[#c9873a] mb-4">Get in touch</p>
        <h1 class="font-display text-6xl font-normal text-[#e8e0d0] mb-1">Let's build</h1>
        <h2 class="font-display text-6xl font-normal italic text-[#c9873a] mb-8">something great.</h2>
        <p class="text-sm leading-relaxed text-white/45 font-light max-w-sm">Whether you have a project in mind, want to talk shop about mobile engineering, or just want to connect — I'm always open to a good conversation.</p>
      </div>

      <div class="divide-y divide-white/[0.08]">
        <div class="flex items-center justify-between py-4">
          <span class="font-mono text-[9px] tracking-widest uppercase text-white/25">LinkedIn</span>
          <a href="https://www.linkedin.com/in/wilbert-veloz-22409821a/" target="_blank" class="text-sm text-white/55 font-light border-b border-white/20 pb-px hover:text-white/80 transition-colors">Wilbert Veloz</a>
        </div>
        <div class="flex items-center justify-between py-4">
          <span class="font-mono text-[9px] tracking-widest uppercase text-white/25">GitHub</span>
          <a href="https://github.com/Wveloz" target="_blank" class="text-sm text-white/55 font-light border-b border-white/20 pb-px hover:text-white/80 transition-colors">Wveloz</a>
        </div>
        <div class="flex items-center justify-between py-4">
          <span class="font-mono text-[9px] tracking-widest uppercase text-white/25">Email</span>
          <a href="mailto:your@email.com" class="text-sm text-white/55 font-light border-b border-white/20 pb-px hover:text-white/80 transition-colors">velozwilbert@gmail.com</a>
        </div>
        <div class="flex items-center justify-between py-4">
          <span class="font-mono text-[9px] tracking-widest uppercase text-white/25">Location</span>
          <span class="text-sm text-white/55 font-light">Santo Domingo, DR</span>
        </div>
      </div>
    </div>

    <!-- RIGHT -->
    <div class="px-10 py-16 flex flex-col justify-center">
      <p class="font-mono text-[10px] tracking-[0.18em] uppercase text-[#c9873a] mb-8">Send a message</p>

      <form id="contact-form" action="https://formspree.io/f/xbdpyzeo" method="POST">

        <div class="grid grid-cols-2 gap-4 mb-6">
          <div>
            <label class="font-mono text-[9px] tracking-widest uppercase text-white/30 block mb-2">Name</label>
            <input type="text" name="name" placeholder="Your name" required
              class="w-full bg-white/[0.03] border border-white/10 text-[#e8e0d0] px-4 py-3 text-sm font-light placeholder:text-white/20 outline-none focus:border-[#c9873a]/50 transition-colors" />
          </div>
          <div>
            <label class="font-mono text-[9px] tracking-widest uppercase text-white/30 block mb-2">Email</label>
            <input type="email" name="email" placeholder="your@email.com" required
              class="w-full bg-white/[0.03] border border-white/10 text-[#e8e0d0] px-4 py-3 text-sm font-light placeholder:text-white/20 outline-none focus:border-[#c9873a]/50 transition-colors" />
          </div>
        </div>

        <div class="mb-6">
          <label class="font-mono text-[9px] tracking-widest uppercase text-white/30 block mb-2">Subject</label>
          <input type="text" name="subject" placeholder="What's this about?" required
            class="w-full bg-white/[0.03] border border-white/10 text-[#e8e0d0] px-4 py-3 text-sm font-light placeholder:text-white/20 outline-none focus:border-[#c9873a]/50 transition-colors" />
        </div>

        <div class="mb-8">
          <label class="font-mono text-[9px] tracking-widest uppercase text-white/30 block mb-2">Message</label>
          <textarea name="message" placeholder="Tell me about your project or idea..." required rows="5"
            class="w-full bg-white/[0.03] border border-white/10 text-[#e8e0d0] px-4 py-3 text-sm font-light placeholder:text-white/20 outline-none focus:border-[#c9873a]/50 transition-colors resize-none"></textarea>
        </div>

        <button type="submit"
          class="w-full bg-[#c9873a] text-[#0f0e0c] py-4 font-mono text-[10px] tracking-widest uppercase font-medium hover:bg-[#b87830] transition-colors hover:-translate-y-1 transition-all duration-200">
          Send message →
        </button>

      </form>
       <div id="success-msg" class="hidden mt-8 border border-[#c9873a]/30 bg-[#c9873a]/5 px-6 py-5">
            <p class="font-mono text-[10px] tracking-widest uppercase text-[#c9873a] mb-2">Message sent</p>
            <p class="text-sm text-white/50 font-light">Thanks for reaching out — I'll get back to you soon.</p>
       </div>
    </div>

  </div>

</BaseLayout>

  <script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('success-msg') as HTMLElement | null;

  if (form && success) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (btn) {
        btn.textContent = 'Sending...';
        btn.disabled = true;
      }

      const data = new FormData(form);

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' }
        });

        if (res.ok) {
          form.style.opacity = '0';
          form.style.transition = 'opacity 0.4s ease';
          setTimeout(() => {
            form.style.display = 'none';
            success.classList.remove('hidden');
            success.style.opacity = '0';
            success.style.transition = 'opacity 0.4s ease';
            setTimeout(() => success.style.opacity = '1', 50);
          }, 400);
        } else {
          if (btn) {
            btn.textContent = 'Something went wrong — try again';
            btn.disabled = false;
          }
        }
      } catch {
        if (btn) {
          btn.textContent = 'Something went wrong — try again';
          btn.disabled = false;
        }
      }
    });
  }
</script>
