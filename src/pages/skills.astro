---
import BaseLayout from '@pt/layouts/BaseLayout.astro'
---

<BaseLayout title="Skills">
  <section class="px-6 pt-10 pb-8 md:px-10 md:pt-16">
    <a
      href="/"
      class="mb-8 inline-block font-mono text-[10px] tracking-widest text-white/30 uppercase transition-colors hover:text-[#c9873a]"
      >← Back</a
    >
    <p class="mb-4 font-mono text-[11px] tracking-[0.15em] text-[#c9873a] uppercase">Capabilities & tools</p>
    <h1 class="font-display mb-1 text-4xl font-normal text-[#e8e0d0] md:text-6xl">What I bring</h1>
    <h2 class="font-display mb-8 text-4xl font-normal text-[#c9873a] italic md:text-6xl">to every project.</h2>
    <p class="max-w-lg text-[15px] leading-relaxed font-light text-white/50">
      A mix of mobile engineering, technical leadership, and design thinking — built over years of shipping real
      products for real users.
    </p>
  </section>

  <hr class="mx-10 border-white/8" />

  <section class="px-10 py-14">
    <p
      class="mb-10 flex items-center gap-4 font-mono text-[10px] tracking-[0.18em] text-[#c9873a] uppercase after:h-px after:w-20 after:bg-white/10 after:content-['']"
    >
      Core skills
    </p>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <div
        class="rounded-sm border border-white/10 bg-white/[0.02] p-8 transition-all duration-20 hover:-translate-y-1 hover:bg-white/[0.06]"
      >
        <div class="mb-6 flex items-center gap-3">
          <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[#c9873a]"></span>
          <p class="font-mono text-[10px] tracking-[0.15em] text-[#c9873a] uppercase">Mobile development</p>
        </div>
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-sm font-light text-white/70">SwiftUI / Swift</span><div
              class="relative h-px w-16 bg-white/8 md:w-24"
            >
              <div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:90%"></div>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm font-light text-white/70">Kotlin / Android</span><div
              class="relative h-px w-16 bg-white/8 md:w-24"
            >
              <div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:85%"></div>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm font-light text-white/70">JavaScript</span><div
              class="relative h-px w-16 bg-white/8 md:w-24"
            >
              <div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:70%"></div>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm font-light text-white/70">iOS & Android platforms</span><div
              class="relative h-px w-16 bg-white/8 md:w-24"
            >
              <div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:90%"></div>
            </div>
          </div>
        </div>
      </div>

      <div
        class="rounded-sm border border-white/10 bg-white/[0.02] p-8 transition-all duration-20 hover:-translate-y-1 hover:bg-white/[0.06]"
      >
        <div class="mb-6 flex items-center gap-3">
          <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[#c9873a]"></span>
          <p class="font-mono text-[10px] tracking-[0.15em] text-[#c9873a] uppercase">Engineering</p>
        </div>
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-sm font-light text-white/70">Data architecture</span><div
              class="relative h-px w-16 bg-white/8 md:w-24"
            >
              <div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:85%"></div>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm font-light text-white/70">Backend integration</span><div
              class="relative h-px w-16 bg-white/8 md:w-24"
            >
              <div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:80%"></div>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm font-light text-white/70">Security controls</span><div
              class="relative h-px w-16 bg-white/8 md:w-24"
            >
              <div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:75%"></div>
            </div>
          </div>
        </div>
      </div>

      <div
        class="rounded-sm border border-white/10 bg-white/[0.02] p-8 transition-all duration-20 hover:-translate-y-1 hover:bg-white/[0.06]"
      >
        <div class="mb-6 flex items-center gap-3">
          <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[#c9873a]"></span>
          <p class="font-mono text-[10px] tracking-[0.15em] text-[#c9873a] uppercase">Leadership</p>
        </div>
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-sm font-light text-white/70">Agile / Scrum</span><div
              class="relative h-px w-16 bg-white/8 md:w-24"
            >
              <div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:90%"></div>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm font-light text-white/70">Technical documentation</span><div
              class="relative h-px w-16 bg-white/8 md:w-24"
            >
              <div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:85%"></div>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm font-light text-white/70">Risk management</span><div
              class="relative h-px w-16 bg-white/8 md:w-24"
            >
              <div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:80%"></div>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm font-light text-white/70">Feature planning</span><div
              class="relative h-px w-16 bg-white/8 md:w-24"
            >
              <div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:85%"></div>
            </div>
          </div>
        </div>
      </div>

      <div
        class="rounded-sm border border-white/10 bg-white/[0.02] p-8 transition-all duration-20 hover:-translate-y-1 hover:bg-white/[0.06]"
      >
        <div class="mb-6 flex items-center gap-3">
          <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[#c9873a]"></span>
          <p class="font-mono text-[10px] tracking-[0.15em] text-[#c9873a] uppercase">Design & quality</p>
        </div>
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-sm font-light text-white/70">UX/UI decision making</span><div
              class="relative h-px w-16 bg-white/8 md:w-24"
            >
              <div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:75% "></div>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm font-light text-white/70">QA strategy & planning</span><div
              class="relative h-px w-16 bg-white/8 md:w-24"
            >
              <div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:80%"></div>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm font-light text-white/70">Test management</span><div
              class="relative h-px w-16 bg-white/8 md:w-24"
            >
              <div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:85%"></div>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm font-light text-white/70">End-to-end testing</span><div
              class="relative h-px w-16 bg-white/8 md:w-24"
            >
              <div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:80%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="mx-10 border-white/8" />

  <section class="px-6 py-10 md:px-10 md:py-14">
    <p
      class="mb-8 flex items-center gap-4 font-mono text-[10px] tracking-[0.18em] text-[#c9873a] uppercase after:h-px after:w-20 after:bg-white/10 after:content-['']"
    >
      Tools & technologies
    </p>
    <div class="flex flex-wrap gap-3">
      <span
        class="cursor-default border border-white/10 px-4 py-2 font-mono text-[10px] tracking-wide text-white/50 transition-all transition-colors duration-200 hover:-translate-y-1 hover:border-[#c9873a]/50 hover:text-[#c9873a]"
        >SwiftUI</span
      >
      <span
        class="cursor-default border border-white/10 px-4 py-2 font-mono text-[10px] tracking-wide text-white/50 transition-all transition-colors duration-200 hover:-translate-y-1 hover:border-[#c9873a]/50 hover:text-[#c9873a]"
        >Kotlin</span
      >
      <span
        class="cursor-default border border-white/10 px-4 py-2 font-mono text-[10px] tracking-wide text-white/50 transition-all transition-colors duration-200 hover:-translate-y-1 hover:border-[#c9873a]/50 hover:text-[#c9873a]"
        >React Native</span
      >
      <span
        class="cursor-default border border-white/10 px-4 py-2 font-mono text-[10px] tracking-wide text-white/50 transition-all transition-colors duration-200 hover:-translate-y-1 hover:border-[#c9873a]/50 hover:text-[#c9873a]"
        >Xcode</span
      >
      <span
        class="cursor-default border border-white/10 px-4 py-2 font-mono text-[10px] tracking-wide text-white/50 transition-all transition-colors duration-200 hover:-translate-y-1 hover:border-[#c9873a]/50 hover:text-[#c9873a]"
        >Android Studio</span
      >
      <span
        class="cursor-default border border-white/10 px-4 py-2 font-mono text-[10px] tracking-wide text-white/50 transition-all transition-colors duration-200 hover:-translate-y-1 hover:border-[#c9873a]/50 hover:text-[#c9873a]"
        >Git</span
      >
      <span
        class="cursor-default border border-white/10 px-4 py-2 font-mono text-[10px] tracking-wide text-white/50 transition-all transition-colors duration-200 hover:-translate-y-1 hover:border-[#c9873a]/50 hover:text-[#c9873a]"
        >CI/CD pipelines</span
      >
      <span
        class="cursor-default border border-white/10 px-4 py-2 font-mono text-[10px] tracking-wide text-white/50 transition-all transition-colors duration-200 hover:-translate-y-1 hover:border-[#c9873a]/50 hover:text-[#c9873a]"
        >REST APIs</span
      >
      <span
        class="cursor-default border border-white/10 px-4 py-2 font-mono text-[10px] tracking-wide text-white/50 transition-all transition-colors duration-200 hover:-translate-y-1 hover:border-[#c9873a]/50 hover:text-[#c9873a]"
        >Agile / Scrum</span
      >
      <span
        class="cursor-default border border-white/10 px-4 py-2 font-mono text-[10px] tracking-wide text-white/50 transition-all transition-colors duration-200 hover:-translate-y-1 hover:border-[#c9873a]/50 hover:text-[#c9873a]"
        >Jira</span
      >
      <span
        class="cursor-default border border-white/10 px-4 py-2 font-mono text-[10px] tracking-wide text-white/50 transition-all transition-colors duration-200 hover:-translate-y-1 hover:border-[#c9873a]/50 hover:text-[#c9873a]"
        >Figma</span
      >
      <span
        class="cursor-default border border-white/10 px-4 py-2 font-mono text-[10px] tracking-wide text-white/50 transition-all transition-colors duration-200 hover:-translate-y-1 hover:border-[#c9873a]/50 hover:text-[#c9873a]"
        >Postman</span
      >
      <span
        class="cursor-default border border-white/10 px-4 py-2 font-mono text-[10px] tracking-wide text-white/50 transition-all transition-colors duration-200 hover:-translate-y-1 hover:border-[#c9873a]/50 hover:text-[#c9873a]"
        >TestFlight</span
      >
      <span
        class="cursor-default border border-white/10 px-4 py-2 font-mono text-[10px] tracking-wide text-white/50 transition-all transition-colors duration-200 hover:-translate-y-1 hover:border-[#c9873a]/50 hover:text-[#c9873a]"
        >Firebase</span
      >
    </div>
  </section>
</BaseLayout>
