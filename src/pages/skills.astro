---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Skills">

  <section class="px-10 pt-16 pb-8">
    <a href="/" class="font-mono text-[10px] tracking-widest uppercase text-white/30 hover:text-[#c9873a] transition-colors mb-8 inline-block">← Back</a>
    <p class="font-mono text-[11px] tracking-[0.15em] uppercase text-[#c9873a] mb-4">Capabilities & tools</p>
    <h1 class="font-display text-6xl font-normal text-[#e8e0d0] mb-1">What I bring</h1>
    <h2 class="font-display text-6xl font-normal italic text-[#c9873a] mb-8">to every project.</h2>
    <p class="text-[15px] leading-relaxed text-white/50 font-light max-w-lg">A mix of mobile engineering, technical leadership, and design thinking — built over years of shipping real products for real users.</p>
  </section>

  <hr class="border-white/8 mx-10" />

  <section class="px-10 py-14">
    <p class="font-mono text-[10px] tracking-[0.18em] uppercase text-[#c9873a] mb-10 flex items-center gap-4 after:content-[''] after:h-px after:w-20 after:bg-white/10">Core skills</p>

    <div class="grid grid-cols-2 gap-6 mb-0">

      <div class="border border-white/10 rounded-sm p-8 bg-white/[0.02] hover:bg-white/[0.06] hover:-translate-y-1 transition-all duration-20">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#c9873a] flex-shrink-0"></span>
          <p class="font-mono text-[10px] tracking-[0.15em] uppercase text-[#c9873a]">Mobile development</p>
        </div>
        <div class="space-y-4">
          <div class="flex items-center justify-between"><span class="text-sm text-white/70 font-light">SwiftUI / Swift</span><div class="w-24 h-px bg-white/8 relative "><div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:90%"></div></div></div>
          <div class="flex items-center justify-between"><span class="text-sm text-white/70 font-light">Kotlin / Android</span><div class="w-24 h-px bg-white/8 relative"><div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:85%"></div></div></div>
          <div class="flex items-center justify-between"><span class="text-sm text-white/70 font-light">JavaScript</span><div class="w-24 h-px bg-white/8 relative"><div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:70%"></div></div></div>
          <div class="flex items-center justify-between"><span class="text-sm text-white/70 font-light">iOS & Android platforms</span><div class="w-24 h-px bg-white/8 relative"><div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:90%"></div></div></div>
        </div>
      </div>

      <div class="border border-white/10 rounded-sm p-8 bg-white/[0.02] hover:bg-white/[0.06] hover:-translate-y-1 transition-all duration-20">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#c9873a] flex-shrink-0"></span>
          <p class="font-mono text-[10px] tracking-[0.15em] uppercase text-[#c9873a]">Engineering</p>
        </div>
        <div class="space-y-4">
          <div class="flex items-center justify-between"><span class="text-sm text-white/70 font-light">Data architecture</span><div class="w-24 h-px bg-white/8 relative"><div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:85%"></div></div></div>
          <div class="flex items-center justify-between"><span class="text-sm text-white/70 font-light">Backend integration</span><div class="w-24 h-px bg-white/8 relative"><div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:80%"></div></div></div>
          <div class="flex items-center justify-between"><span class="text-sm text-white/70 font-light">Security controls</span><div class="w-24 h-px bg-white/8 relative"><div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:75%"></div></div></div>
        </div>
      </div>

      <div class="border border-white/10 rounded-sm p-8 bg-white/[0.02] hover:bg-white/[0.06] hover:-translate-y-1 transition-all duration-20">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#c9873a] flex-shrink-0"></span>
          <p class="font-mono text-[10px] tracking-[0.15em] uppercase text-[#c9873a]">Leadership</p>
        </div>
        <div class="space-y-4">
          <div class="flex items-center justify-between"><span class="text-sm text-white/70 font-light">Agile / Scrum</span><div class="w-24 h-px bg-white/8 relative"><div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:90%"></div></div></div>
          <div class="flex items-center justify-between"><span class="text-sm text-white/70 font-light">Technical documentation</span><div class="w-24 h-px bg-white/8 relative"><div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:85%"></div></div></div>
          <div class="flex items-center justify-between"><span class="text-sm text-white/70 font-light">Risk management</span><div class="w-24 h-px bg-white/8 relative"><div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:80%"></div></div></div>
          <div class="flex items-center justify-between"><span class="text-sm text-white/70 font-light">Feature planning</span><div class="w-24 h-px bg-white/8 relative"><div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:85%"></div></div></div>
        </div>
      </div>

      <div class="border border-white/10 rounded-sm p-8 bg-white/[0.02] hover:bg-white/[0.06] hover:-translate-y-1 transition-all duration-20">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#c9873a] flex-shrink-0"></span>
          <p class="font-mono text-[10px] tracking-[0.15em] uppercase text-[#c9873a]">Design & quality</p>
        </div>
        <div class="space-y-4">
          <div class="flex items-center justify-between"><span class="text-sm text-white/70 font-light">UX/UI decision making</span><div class="w-24 h-px bg-white/8 relative"><div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:75% "></div></div></div>
          <div class="flex items-center justify-between"><span class="text-sm text-white/70 font-light">QA strategy & planning</span><div class="w-24 h-px bg-white/8 relative"><div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:80%"></div></div></div>
          <div class="flex items-center justify-between"><span class="text-sm text-white/70 font-light">Test management</span><div class="w-24 h-px bg-white/8 relative"><div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:85%"></div></div></div>
          <div class="flex items-center justify-between"><span class="text-sm text-white/70 font-light">End-to-end testing</span><div class="w-24 h-px bg-white/8 relative"><div class="absolute top-0 left-0 h-px bg-[#c9873a]" style="width:80%"></div></div></div>
        </div>
      </div>

    </div>
  </section>

  <hr class="border-white/8 mx-10" />

  <section class="px-10 py-14">
    <p class="font-mono text-[10px] tracking-[0.18em] uppercase text-[#c9873a] mb-8 flex items-center gap-4 after:content-[''] after:h-px after:w-20 after:bg-white/10">Tools & technologies</p>
    <div class="flex flex-wrap gap-3">
  <span class="font-mono text-[10px] text-white/50 border border-white/10 px-4 py-2 tracking-wide hover:text-[#c9873a] hover:border-[#c9873a]/50 transition-colors cursor-default hover:-translate-y-1 transition-all duration-200">SwiftUI</span>
  <span class="font-mono text-[10px] text-white/50 border border-white/10 px-4 py-2 tracking-wide hover:text-[#c9873a] hover:border-[#c9873a]/50 transition-colors cursor-default hover:-translate-y-1 transition-all duration-200">Kotlin</span>
  <span class="font-mono text-[10px] text-white/50 border border-white/10 px-4 py-2 tracking-wide hover:text-[#c9873a] hover:border-[#c9873a]/50 transition-colors cursor-default hover:-translate-y-1 transition-all duration-200">React Native</span>
  <span class="font-mono text-[10px] text-white/50 border border-white/10 px-4 py-2 tracking-wide hover:text-[#c9873a] hover:border-[#c9873a]/50 transition-colors cursor-default hover:-translate-y-1 transition-all duration-200">Xcode</span>
  <span class="font-mono text-[10px] text-white/50 border border-white/10 px-4 py-2 tracking-wide hover:text-[#c9873a] hover:border-[#c9873a]/50 transition-colors cursor-default hover:-translate-y-1 transition-all duration-200">Android Studio</span>
  <span class="font-mono text-[10px] text-white/50 border border-white/10 px-4 py-2 tracking-wide hover:text-[#c9873a] hover:border-[#c9873a]/50 transition-colors cursor-default hover:-translate-y-1 transition-all duration-200">Git</span>
  <span class="font-mono text-[10px] text-white/50 border border-white/10 px-4 py-2 tracking-wide hover:text-[#c9873a] hover:border-[#c9873a]/50 transition-colors cursor-default hover:-translate-y-1 transition-all duration-200">CI/CD pipelines</span>
  <span class="font-mono text-[10px] text-white/50 border border-white/10 px-4 py-2 tracking-wide hover:text-[#c9873a] hover:border-[#c9873a]/50 transition-colors cursor-default hover:-translate-y-1 transition-all duration-200">REST APIs</span>
  <span class="font-mono text-[10px] text-white/50 border border-white/10 px-4 py-2 tracking-wide hover:text-[#c9873a] hover:border-[#c9873a]/50 transition-colors cursor-default hover:-translate-y-1 transition-all duration-200">Agile / Scrum</span>
  <span class="font-mono text-[10px] text-white/50 border border-white/10 px-4 py-2 tracking-wide hover:text-[#c9873a] hover:border-[#c9873a]/50 transition-colors cursor-default hover:-translate-y-1 transition-all duration-200">Jira</span>
  <span class="font-mono text-[10px] text-white/50 border border-white/10 px-4 py-2 tracking-wide hover:text-[#c9873a] hover:border-[#c9873a]/50 transition-colors cursor-default hover:-translate-y-1 transition-all duration-200">Figma</span>
  <span class="font-mono text-[10px] text-white/50 border border-white/10 px-4 py-2 tracking-wide hover:text-[#c9873a] hover:border-[#c9873a]/50 transition-colors cursor-default hover:-translate-y-1 transition-all duration-200">Postman</span>
  <span class="font-mono text-[10px] text-white/50 border border-white/10 px-4 py-2 tracking-wide hover:text-[#c9873a] hover:border-[#c9873a]/50 transition-colors cursor-default hover:-translate-y-1 transition-all duration-200">TestFlight</span>
  <span class="font-mono text-[10px] text-white/50 border border-white/10 px-4 py-2 tracking-wide hover:text-[#c9873a] hover:border-[#c9873a]/50 transition-colors cursor-default hover:-translate-y-1 transition-all duration-200">Firebase</span>
</div>
    </div>
  </section>

</BaseLayout>