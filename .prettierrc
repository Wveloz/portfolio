{
  "plugins": ["prettier-plugin-astro", "prettier-plugin-tailwindcss"],
  "arrowParens": "always",
  "endOfLine": "lf",
  "printWidth": 120,
  "semi": false,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "tailwindFunctions": ["cva", "cx", "lcx"],
  "tailwindStylesheet": "./src/styles/global.css",
  "overrides": [
    {
      "files": "*.astro",
      "options": { "parser": "astro" }
    },
    {
      "files": "*.json*",
      "options": { "trailingComma": "none" }
    }
  ]
}

